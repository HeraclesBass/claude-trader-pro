{
  "name": "claude-trader-pro-tests",
  "version": "1.0.0",
  "description": "E2E test suite for ClaudeTrader Pro",
  "scripts": {
    "test": "jest --coverage --verbose",
    "test:api": "jest tests/api --verbose",
    "test:websocket": "jest tests/websocket --verbose",
    "test:integration": "jest --testPathPattern=integration --runInBand",
    "test:e2e": "playwright test",
    "test:performance": "k6 run tests/performance/test_load.js",
    "test:watch": "jest --watch",
    "test:ci": "jest --ci --coverage --maxWorkers=2"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.1",
    "@types/jest": "^29.5.11",
    "jest": "^29.7.0",
    "socket.io-client": "^4.6.1",
    "supertest": "^6.3.3",
    "k6": "^0.48.0"
  },
  "dependencies": {
    "axios": "^1.6.2",
    "pg": "^8.11.3"
  },
  "jest": {
    "testEnvironment": "node",
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "../backend/**/*.js",
      "!../backend/**/node_modules/**",
      "!../backend/**/*.test.js",
      "!../backend/**/*.spec.js"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 70,
        "functions": 75,
        "lines": 80,
        "statements": 80
      }
    },
    "testTimeout": 30000,
    "setupFilesAfterEnv": ["<rootDir>/utils/test-setup.js"]
  }
}
